{
  "name": "ngx-cookie-service-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:ssr": "ng serve ngx-cookie-service-ssr-demo --port=4203",
    "build": "ng build ngx-cookie-service",
    "build:ngx-cookie-service-ssr": "ng build ngx-cookie-service-ssr",
    "build:ssr-demo": "ng build ngx-cookie-service-ssr-demo",
    "test": "ng test ngx-cookie-service --watch=false",
    "test:ngx-cookie-service-ssr": "ng test ngx-cookie-service-ssr",
    "lint": "ng lint ngx-cookie-service",
    "lint:ngx-cookie-service-ssr": "ng lint ngx-cookie-service-ssr",
    "e2e": "ng e2e",
    "format": "prettier ./projects/**/*.{ts,json}",
    "format:write": "npm run format -- --write",
    "format:check": "npm run format -- --check",
    "package": "ng build ngx-cookie-service --configuration=production && cp ./README.md ./dist/ngx-cookie-service && cd dist/ngx-cookie-service && npm pack",
    "serve:ssr:ngx-cookie-service-ssr-demo": "node dist/ngx-cookie-service-ssr-demo/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "~22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "~22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/language-service": "^22.0.0",
    "@netlify/angular-runtime": "^4.0.0",
    "@types/node": "^25.9.1",
    "@vitest/browser-playwright": "^4.1.8",
    "angular-eslint": "21.4.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^63.0.1",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "jsdom": "^29.1.1",
    "ng-packagr": "^22.0.0",
    "prettier": "3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.1.8"
  }
}
